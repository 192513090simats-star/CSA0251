#include <stdio.h>
int main() 
{
    int n, a = 0, b = 1, c;
    int count = 0, sum = 0;
    printf("Enter n: ");
    scanf("%d", &n);
    while(count < n)
    {
        if(a % 2 == 0)   // check even Fibonacci
        {
            sum = sum + a;
            count++;
        }
        c = a + b;
        a = b;
        b = c;
    }
    printf("Sum = %d", sum);
    return 0;
}
