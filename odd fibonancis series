#include <stdio.h>
int main() 
{
    int n, a = 0, b = 1, c;
    printf("Enter limit: ");
    scanf("%d", &n);
    printf("Odd Fibonacci series: ");
    while(a <= n)
    {
        if(a % 2 != 0)   // check odd
        {
            printf("%d ", a);
        }
        c = a + b;
        a = b;
        b = c;
    }
    return 0;
}
